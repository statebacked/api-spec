#!/usr/bin/env node

"use strict";

const fs = require("node:fs");
const path = require("node:path");
const yaml = require("js-yaml");

const DEFAULT_SPEC = "statebacked.openapi.v3.yaml";
const DEFAULT_OUT = "docs";
const HTTP_METHODS = Object.freeze([
  "get",
  "put",
  "post",
  "delete",
  "options",
  "head",
  "patch",
  "trace",
]);

const GENERATED_FILES = Object.freeze([
  "index.html",
  "styles.css",
  "app.js",
  "openapi.yaml",
  "openapi.json",
  "api-docs.json",
  ".nojekyll",
]);

class UsageError extends Error {
  constructor(message) {
    super(message);
    this.name = "UsageError";
  }
}

class GenerationError extends Error {
  constructor(message) {
    super(message);
    this.name = "GenerationError";
  }
}

function parseArgs(argv) {
  const options = {
    spec: DEFAULT_SPEC,
    out: DEFAULT_OUT,
    selfTest: false,
  };

  for (let index = 0; index < argv.length; index += 1) {
    const arg = argv[index];

    if (arg === "--self-test") {
      options.selfTest = true;
      continue;
    }

    if (arg === "--spec" || arg === "--out") {
      const value = argv[index + 1];
      if (!value || value.startsWith("--")) {
        throw new UsageError(`Missing value for ${arg}`);
      }

      options[arg.slice(2)] = value;
      index += 1;
      continue;
    }

    if (arg.startsWith("--")) {
      throw new UsageError(`Unknown flag: ${arg}`);
    }

    throw new UsageError(`Unexpected argument: ${arg}`);
  }

  return options;
}

function resolvePaths(cwd, options) {
  return {
    specPath: path.resolve(cwd, options.spec),
    outDir: path.resolve(cwd, options.out),
  };
}

function assertSpecExists(specPath) {
  let stat;

  try {
    stat = fs.statSync(specPath);
  } catch (error) {
    if (error.code === "ENOENT") {
      throw new UsageError(`Spec file does not exist: ${specPath}`);
    }

    throw error;
  }

  if (!stat.isFile()) {
    throw new UsageError(`Spec path is not a file: ${specPath}`);
  }
}

function loadSpec(specPath) {
  const source = fs.readFileSync(specPath, "utf8");
  let document;

  try {
    document = yaml.load(source);
  } catch (error) {
    if (error && error.name === "YAMLException") {
      throw new GenerationError(
        `Unable to parse OpenAPI YAML at ${specPath}: ${error.reason || error.message}`,
      );
    }

    throw error;
  }

  return {
    source,
    document,
  };
}

function assertOpenApiDocument(document) {
  if (!isPlainObject(document)) {
    throw new GenerationError("OpenAPI document must be a YAML mapping/object.");
  }

  if (typeof document.openapi !== "string" || !document.openapi.trim()) {
    throw new GenerationError("OpenAPI document must include an openapi version string.");
  }

  if (!isPlainObject(document.info)) {
    throw new GenerationError("OpenAPI document must include an info object.");
  }

  if (!isPlainObject(document.paths)) {
    throw new GenerationError("OpenAPI document must include a paths object.");
  }
}

function prepareOutput(outDir) {
  fs.mkdirSync(outDir, { recursive: true });

  for (const fileName of GENERATED_FILES) {
    fs.rmSync(path.join(outDir, fileName), {
      force: true,
      recursive: true,
    });
  }
}

function pageTitle(docsData) {
  return docsData &&
    docsData.api &&
    typeof docsData.api.title === "string" &&
    docsData.api.title.trim()
    ? docsData.api.title.trim()
    : "API Documentation";
}

function renderIndexHtml(docsData) {
  const title = escapeHtml(pageTitle(docsData));
  const version = escapeHtml(docsData.api.version || "unversioned");

  return `<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>${title}</title>
  <link rel="stylesheet" href="styles.css">
</head>
<body>
  <div class="docs-shell">
    <header class="docs-header">
      <div>
        <p class="docs-kicker">OpenAPI ${version}</p>
        <h1>${title}</h1>
      </div>
      <nav class="source-links" aria-label="Source downloads">
        <a href="openapi.yaml" download>OpenAPI YAML</a>
        <a href="openapi.json" download>OpenAPI JSON</a>
        <a href="api-docs.json" download>Docs data</a>
      </nav>
    </header>
    <div class="docs-layout">
      <aside class="docs-sidebar" aria-label="Documentation navigation">
        <label class="search-label" for="docs-search">Search API docs</label>
        <input id="docs-search" class="search-input" type="search" autocomplete="off" spellcheck="false" placeholder="Search topics, endpoints, schemas">
        <nav id="docs-navigation" class="docs-navigation" aria-label="API sections">
          <a href="#/" data-route-id="overview">Overview</a>
          <a href="#/topics" data-route-pattern="#/topics/:slug">Topics</a>
          <a href="#/tags" data-route-pattern="#/tags/:slug">Tags</a>
          <a href="#/operations" data-route-pattern="#/operations/:slug">Operations</a>
          <a href="#/schemas" data-route-pattern="#/schemas/:slug">Schemas</a>
        </nav>
      </aside>
      <main id="docs-content" class="docs-content" tabindex="-1" data-route-root="#/">
        <section id="route-overview" data-route="#/" aria-labelledby="overview-title">
          <p class="docs-kicker">Static API documentation</p>
          <h2 id="overview-title">Overview</h2>
          <p id="docs-route-status">Loading generated documentation data.</p>
        </section>
        <section id="route-placeholder" class="route-placeholder" hidden aria-live="polite"></section>
      </main>
    </div>
  </div>
  <script src="app.js"></script>
</body>
</html>
`;
}

