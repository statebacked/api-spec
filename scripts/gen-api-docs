function renderAppJs(docsData) {
  const routeTemplates = {
    overview: "#/",
    topic: "#/topics/:slug",
    tag: "#/tags/:slug",
    operation: "#/operations/:slug",
    schema: "#/schemas/:slug",
  };

  return `"use strict";

const apiDocsData = ${serializeJsonForScript(docsData)};
const apiDocsRoutes = ${serializeJsonForScript(routeTemplates)};

document.documentElement.dataset.apiDocs = "generated";
document.documentElement.dataset.apiTitle = apiDocsData.api.title;
window.apiDocsData = apiDocsData;
window.apiDocsRoutes = apiDocsRoutes;

const docsContent = document.getElementById("docs-content");

const docsIndex = {
  topicsBySlug: indexBy(apiDocsData.topics, "slug"),
  tagsBySlug: indexBy(apiDocsData.tags, "slug"),
  operationsById: indexBy(apiDocsData.operations, "id"),
  schemasByName: indexBy(apiDocsData.components.schemas, "name"),
  schemasBySlug: indexBy(apiDocsData.components.schemas.map(function (schema) {
    return Object.assign({ slug: slugify(schema.name) }, schema);
  }), "slug"),
};

function indexBy(items, key) {
  return arrayValue(items).reduce(function (index, item) {
    if (item && item[key]) {
      index[String(item[key])] = item;
    }

    return index;
  }, {});
}

function parseRoute(hash) {
  const routeHash = hash && hash !== "#" ? hash : "#/";
  const route = routeHash.split("?")[0].replace(/^#/, "");
  const parts = route.split("/").filter(Boolean).map(decodeRouteSegment);

  if (parts.length === 0) {
    return { type: "overview" };
  }

  if (parts.length === 1 && ["topics", "tags", "operations", "schemas"].includes(parts[0])) {
    return { type: parts[0] };
  }

  if (parts.length === 2 && parts[0] === "topics") {
    return { type: "topic", key: parts[1] };
  }

  if (parts.length === 2 && parts[0] === "tags") {
    return { type: "tag", key: parts[1] };
  }

  if (parts.length === 2 && parts[0] === "operations") {
    return { type: "operation", key: parts[1] };
  }

  if (parts.length === 2 && parts[0] === "schemas") {
    return { type: "schema", key: parts[1] };
  }

  return { type: "notFound", key: routeHash };
}

function dispatchView(route) {
  if (route.type === "overview") {
    return renderOverview();
  }

  if (route.type === "topics") {
    return renderCollection("Topics", "Spec narrative topics", apiDocsData.topics, renderTopicLink);
  }

  if (route.type === "tags") {
    return renderCollection("Tags", "Operation groups from the OpenAPI tags", apiDocsData.tags, renderTagLink);
  }

  if (route.type === "operations") {
    return renderCollection("Operations", "Endpoints grouped by method and path", apiDocsData.operations, renderOperationLink);
  }

  if (route.type === "schemas") {
    return renderCollection("Schemas", "Component schemas available from this API", apiDocsData.components.schemas, renderSchemaLink);
  }

  if (route.type === "topic") {
    return docsIndex.topicsBySlug[route.key]
      ? renderTopic(docsIndex.topicsBySlug[route.key])
      : renderNotFound("Topic not found", route.key);
  }

  if (route.type === "tag") {
    return docsIndex.tagsBySlug[route.key]
      ? renderTag(docsIndex.tagsBySlug[route.key])
      : renderNotFound("Tag not found", route.key);
  }

  if (route.type === "operation") {
    return docsIndex.operationsById[route.key]
      ? renderOperation(docsIndex.operationsById[route.key])
      : renderNotFound("Operation not found", route.key);
  }

  if (route.type === "schema") {
    const schema = docsIndex.schemasByName[route.key] || docsIndex.schemasBySlug[route.key];
    return schema ? renderSchemaPage(schema) : renderNotFound("Schema not found", route.key);
  }

  return renderNotFound("Route not found", route.key || window.location.hash);
}

function renderCurrentRoute() {
  if (!docsContent) {
    return;
  }

  const route = parseRoute(window.location.hash);
  docsContent.innerHTML = dispatchView(route);
  docsContent.focus({ preventScroll: true });
  markActiveRoute(route);
}

function markActiveRoute(route) {
  const links = document.querySelectorAll("#docs-navigation a");
  const routeRoot = route.type === "overview" ? "overview" : route.type.replace(/s$/, "");

  links.forEach(function (link) {
    const routeId = link.getAttribute("data-route-id");
    const routePattern = link.getAttribute("data-route-pattern") || "";
    const isActive =
      routeId === routeRoot ||
      (route.type !== "overview" && routePattern.indexOf("#/" + collectionName(route.type)) === 0);

    link.toggleAttribute("aria-current", isActive);
  });
}

function collectionName(type) {
  if (type === "topic") {
    return "topics";
  }

  if (type === "tag") {
    return "tags";
  }

  if (type === "operation") {
    return "operations";
  }

  if (type === "schema") {
    return "schemas";
  }

  return type;
}

function renderOverview() {
  const api = apiDocsData.api;
  const servers = arrayValue(api.servers);
  const primaryServer = servers[0] && servers[0].url ? servers[0].url : "";

  return [
    '<article id="route-overview" class="route-view" data-route="#/">',
    renderRouteHeading("Static API documentation", api.title || "API Documentation", "Version " + (api.version || "unversioned")),
    renderMarkdown(api.description),
    '<section id="overview-metadata" class="content-section" aria-labelledby="overview-metadata-title">',
    '<header><h3 id="overview-metadata-title">API Metadata</h3></header>',
    '<ul class="metadata-list">',
    metadataItem("OpenAPI", api.openapi),
    metadataItem("Base URL", primaryServer),
    api.externalDocs && api.externalDocs.url
      ? '<li><strong>External docs:</strong> <a href="' + safeUrl(api.externalDocs.url) + '">' + escapeHtml(api.externalDocs.description || api.externalDocs.url) + '</a></li>'
      : "",
    '</ul>',
    '</section>',
    renderCollectionSection("Topics", apiDocsData.topics, renderTopicLink),
    renderCollectionSection("Tag Groups", apiDocsData.tags, renderTagLink),
    renderCollectionSection("Source Downloads", [
      { title: "OpenAPI YAML", href: "openapi.yaml" },
      { title: "OpenAPI JSON", href: "openapi.json" },
      { title: "Docs data", href: "api-docs.json" },
    ], function (item) {
      return '<a href="' + escapeHtml(item.href) + '" download>' + escapeHtml(item.title) + '</a>';
    }),
    '</article>',
  ].join("");
}

function renderTopic(topic) {
  return [
    '<article id="' + escapeHtml(topic.routeId) + '" class="route-view" data-route="#/topics/' + encodeRouteSegment(topic.slug) + '">',
    renderRouteHeading("Topic", topic.title, ""),
    renderMarkdown(topic.content),
    '</article>',
  ].join("");
}

function renderTag(tag) {
  const operations = arrayValue(tag.operationIds)
    .map(function (operationId) {
      return docsIndex.operationsById[operationId];
    })
    .filter(Boolean);

  return [
    '<article id="' + escapeHtml(tag.routeId) + '" class="route-view" data-route="#/tags/' + encodeRouteSegment(tag.slug) + '">',
    renderRouteHeading("Tag", tag.name, operations.length + " operations"),
    renderMarkdown(tag.description),
    renderCollectionSection("Operations", operations, renderOperationLink),
    '</article>',
  ].join("");
}

function renderOperation(operation) {
  return [
    '<article id="' + escapeHtml(operation.routeId) + '" class="route-view" data-route="#/operations/' + encodeRouteSegment(operation.id) + '">',
    '<header class="route-heading">',
    '<p class="docs-kicker">Operation</p>',
    '<div class="operation-title">',
    renderMethodBadge(operation.method),
    '<h2>' + escapeHtml(operation.summary || operation.operationId || operation.id) + '</h2>',
    '</div>',
    '<p class="path-text">' + escapeHtml(operation.path) + '</p>',
    '</header>',
    renderMarkdown(operation.description),
    renderOperationMetadata(operation),
    renderParameters(operation.parameters),
    renderRequestBody(operation.requestBody),
    renderResponses(operation.responses),
    renderSecurity(operation.security),
    '</article>',
  ].join("");
}

function renderSchemaPage(schema) {
  return [
    '<article id="' + escapeHtml(schema.routeId) + '" class="route-view" data-route="#/schemas/' + encodeRouteSegment(schema.name) + '">',
    renderRouteHeading("Schema", schema.name, schema.ref),
    renderSchema(schema.shape, { id: schema.routeId + "-shape", path: schema.name, depth: 0 }),
    '</article>',
  ].join("");
}

function renderNotFound(title, detail) {
  return [
    '<article id="route-not-found" class="route-view not-found">',
    renderRouteHeading("Not found", title, ""),
    '<p class="muted">' + escapeHtml(detail || "The requested documentation route does not exist.") + '</p>',
    '<p><a href="#/">Back to overview</a></p>',
    '</article>',
  ].join("");
}

function renderCollection(title, subtitle, items, renderItem) {
  return [
    '<article class="route-view">',
    renderRouteHeading("Documentation", title, subtitle),
    '<ul class="docs-list">',
    arrayValue(items).map(function (item) {
      return '<li>' + renderItem(item) + '</li>';
    }).join(""),
    '</ul>',
    '</article>',
  ].join("");
}

function renderCollectionSection(title, items, renderItem) {
  const id = slugify(title);
  const renderedItems = arrayValue(items).map(function (item) {
    return '<li>' + renderItem(item) + '</li>';
  }).join("");

  return [
    '<section id="' + escapeHtml(id) + '" class="content-section" aria-labelledby="' + escapeHtml(id) + '-title">',
    '<header><h3 id="' + escapeHtml(id) + '-title">' + escapeHtml(title) + '</h3></header>',
    renderedItems ? '<ul class="docs-list">' + renderedItems + '</ul>' : '<p class="empty-state">None documented.</p>',
    '</section>',
  ].join("");
}

function renderRouteHeading(kicker, title, subtitle) {
  return [
    '<header class="route-heading">',
    kicker ? '<p class="docs-kicker">' + escapeHtml(kicker) + '</p>' : "",
    '<h2>' + escapeHtml(title) + '</h2>',
    subtitle ? '<p class="muted">' + escapeHtml(subtitle) + '</p>' : "",
    '</header>',
  ].join("");
}

function renderOperationMetadata(operation) {
  const tags = arrayValue(operation.tags).map(function (tagName) {
    const tag = apiDocsData.tags.find(function (candidate) {
      return candidate.name === tagName;
    });

    return tag ? '<a href="#/tags/' + encodeRouteSegment(tag.slug) + '">' + escapeHtml(tag.name) + '</a>' : escapeHtml(tagName);
  }).join(", ");

  return [
    '<section id="' + escapeHtml(operation.routeId) + '-metadata" class="content-section" aria-labelledby="' + escapeHtml(operation.routeId) + '-metadata-title">',
    '<header><h3 id="' + escapeHtml(operation.routeId) + '-metadata-title">Metadata</h3></header>',
    '<ul class="metadata-list">',
    metadataItem("Operation ID", operation.operationId),
    tags ? '<li><strong>Tags:</strong> ' + tags + '</li>' : "",
    '</ul>',
    '</section>',
  ].join("");
}

function renderParameters(parameters) {
  const rows = arrayValue(parameters).map(function (parameter) {
    return [
      '<tr id="parameter-' + escapeHtml(slugify(parameter.in + "-" + parameter.name)) + '">',
      '<td><code>' + escapeHtml(parameter.name) + '</code></td>',
      '<td>' + escapeHtml(parameter.in) + '</td>',
      '<td>' + (parameter.required ? '<span class="required-badge">required</span>' : '<span class="muted">optional</span>') + (parameter.deprecated ? ' <span class="deprecated-badge">deprecated</span>' : "") + '</td>',
      '<td>' + renderSchemaSummary(parameter.schema) + renderMarkdown(parameter.description) + renderExamples(parameter) + '</td>',
      '</tr>',
    ].join("");
  }).join("");

  return [
    '<section id="parameters" class="content-section" aria-labelledby="parameters-title">',
    '<header><h3 id="parameters-title">Parameters</h3></header>',
    rows
      ? '<table class="parameter-table"><thead><tr><th>Name</th><th>In</th><th>Required</th><th>Details</th></tr></thead><tbody>' + rows + '</tbody></table>'
      : '<p class="empty-state">No parameters documented.</p>',
    '</section>',
  ].join("");
}

function renderRequestBody(requestBody) {
  if (!requestBody) {
    return [
      '<section id="request-body" class="content-section" aria-labelledby="request-body-title">',
      '<header><h3 id="request-body-title">Request Body</h3></header>',
      '<p class="empty-state">No request body documented.</p>',
      '</section>',
    ].join("");
  }

  return [
    '<section id="request-body" class="content-section" aria-labelledby="request-body-title">',
    '<header><h3 id="request-body-title">Request Body</h3>',
    requestBody.required ? '<span class="required-badge">required</span>' : "",
    '</header>',
    requestBody.ref ? '<p>' + renderRefLink(requestBody.ref) + '</p>' : "",
    renderMarkdown(requestBody.description),
    renderMediaList(requestBody.content, "request-body"),
    '</section>',
  ].join("");
}

function renderResponses(responses) {
  const responseBlocks = arrayValue(responses).map(function (response) {
    const id = "response-" + slugify(response.status);

    return [
      '<section id="' + escapeHtml(id) + '" class="response-block" aria-labelledby="' + escapeHtml(id) + '-title">',
      '<header><h4 id="' + escapeHtml(id) + '-title">' + escapeHtml(response.status) + '</h4>',
      response.ref ? renderRefLink(response.ref) : "",
      '</header>',
      renderMarkdown(response.description),
      renderMediaList(response.content, id),
      '</section>',
    ].join("");
  }).join("");

  return [
    '<section id="responses" class="content-section" aria-labelledby="responses-title">',
    '<header><h3 id="responses-title">Responses</h3></header>',
    responseBlocks || '<p class="empty-state">No responses documented.</p>',
    '</section>',
  ].join("");
}

function renderSecurity(security) {
  const items = arrayValue(security).map(function (requirement) {
    if (!isPlainObject(requirement)) {
      return "";
    }

    return Object.keys(requirement).map(function (name) {
      const scopes = arrayValue(requirement[name]);
      return '<li><strong>' + escapeHtml(name) + ':</strong> ' + (scopes.length ? escapeHtml(scopes.join(", ")) : '<span class="muted">no scopes listed</span>') + '</li>';
    }).join("");
  }).join("");

  return [
    '<section id="security" class="content-section" aria-labelledby="security-title">',
    '<header><h3 id="security-title">Security</h3></header>',
    items ? '<ul class="metadata-list">' + items + '</ul>' : '<p class="empty-state">No operation-specific security requirements documented.</p>',
    '</section>',
  ].join("");
}

function renderMediaList(content, idPrefix) {
  const mediaBlocks = arrayValue(content).map(function (media, index) {
    const id = idPrefix + "-media-" + slugify(media.mediaType || String(index + 1));

    return [
      '<section id="' + escapeHtml(id) + '" class="media-block" aria-labelledby="' + escapeHtml(id) + '-title">',
      '<header><h4 id="' + escapeHtml(id) + '-title">' + escapeHtml(media.mediaType || "media") + '</h4></header>',
      renderSchema(media.schema, { id: id + "-schema", path: id, depth: 0 }),
      renderExamples(media),
      '</section>',
    ].join("");
  }).join("");

  return mediaBlocks ? '<div class="media-list">' + mediaBlocks + '</div>' : '<p class="empty-state">No media content documented.</p>';
}

function renderSchema(schema, context) {
  if (!schema) {
    return '<p class="empty-state">No schema documented.</p>';
  }

  if (!isPlainObject(schema)) {
    return '<pre class="json-block"><code>' + escapeHtml(formatJson(schema)) + '</code></pre>';
  }

  const state = Object.assign({ depth: 0, path: "schema" }, context || {});
  const id = state.id || "schema-" + slugify(state.path);
  const parts = [
    '<section id="' + escapeHtml(id) + '" class="schema-block">',
    '<header>',
    '<h4>' + escapeHtml(schemaTitle(schema, state)) + '</h4>',
    '<span class="schema-badge">' + escapeHtml(schemaType(schema)) + '</span>',
    '</header>',
    schema.$ref ? '<p>' + renderRefLink(schema.$ref) + '</p>' : "",
    renderMarkdown(schema.description),
    renderSchemaFacts(schema),
    renderExamples(schema),
  ];

  if (schema.circular) {
    parts.push('<p class="muted">Circular reference omitted.</p>');
  } else if (state.depth < 8) {
    parts.push(renderSchemaComposition(schema, state));
    parts.push(renderArrayItems(schema, state));
    parts.push(renderObjectProperties(schema, state));
    parts.push(renderAdditionalProperties(schema, state));
  }

  parts.push('</section>');
  return parts.join("");
}

function schemaTitle(schema, state) {
  if (state.name) {
    return state.name;
  }

  if (schema.title) {
    return schema.title;
  }

  const pathParts = String(state.path || "").split(".");
  return pathParts[pathParts.length - 1] || "Schema";
}

function schemaType(schema) {
  if (schema.type) {
    return schema.format ? schema.type + ":" + schema.format : schema.type;
  }

  if (schema.enum) {
    return "enum";
  }

  if (schema.oneOf) {
    return "oneOf";
  }

  if (schema.anyOf) {
    return "anyOf";
  }

  if (schema.allOf) {
    return "allOf";
  }

  return "schema";
}

function renderSchemaFacts(schema) {
  const facts = [];

  if (arrayValue(schema.enum).length) {
    facts.push('<li><strong>Enum:</strong> ' + arrayValue(schema.enum).map(function (value) {
      return '<code>' + escapeHtml(String(value)) + '</code>';
    }).join(", ") + '</li>');
  }

  for (const key of ["const", "default", "example", "pattern", "minimum", "maximum", "minLength", "maxLength", "minItems", "maxItems"]) {
    if (Object.prototype.hasOwnProperty.call(schema, key)) {
      facts.push('<li><strong>' + escapeHtml(key) + ':</strong> <code>' + escapeHtml(formatJson(schema[key])) + '</code></li>');
    }
  }

  return facts.length ? '<ul class="metadata-list">' + facts.join("") + '</ul>' : "";
}

function renderSchemaComposition(schema, state) {
  return ["allOf", "anyOf", "oneOf"].map(function (key) {
    const variants = arrayValue(schema[key]);

    if (!variants.length) {
      return "";
    }

    return [
      '<div class="schema-children">',
      '<h5>' + escapeHtml(key) + '</h5>',
      variants.map(function (variant, index) {
        return renderSchema(variant, {
          id: state.id + "-" + key + "-" + (index + 1),
          path: state.path + "." + key + "." + (index + 1),
          depth: state.depth + 1,
        });
      }).join(""),
      '</div>',
    ].join("");
  }).join("");
}

function renderArrayItems(schema, state) {
  if (!schema.items) {
    return "";
  }

  return [
    '<div class="schema-children">',
    '<h5>Items</h5>',
    renderSchema(schema.items, {
      id: state.id + "-items",
      path: state.path + "[]",
      depth: state.depth + 1,
    }),
    '</div>',
  ].join("");
}

function renderObjectProperties(schema, state) {
  const properties = isPlainObject(schema.properties) ? schema.properties : {};
  const propertyNames = Object.keys(properties);

  if (!propertyNames.length) {
    return "";
  }

  const required = new Set(arrayValue(schema.required));
  const blocks = propertyNames.map(function (name) {
    const property = properties[name];
    const id = state.id + "-property-" + slugify(name);

    return [
      '<section id="' + escapeHtml(id) + '" class="property-block">',
      '<header>',
      '<h5><code>' + escapeHtml(name) + '</code></h5>',
      required.has(name) ? '<span class="required-badge">required</span>' : '<span class="muted">optional</span>',
      '</header>',
      renderSchema(property, {
        id: id + "-schema",
        path: state.path + "." + name,
        depth: state.depth + 1,
        name,
      }),
      '</section>',
    ].join("");
  }).join("");

  return '<div class="schema-children"><h5>Properties</h5>' + blocks + '</div>';
}

function renderAdditionalProperties(schema, state) {
  if (!Object.prototype.hasOwnProperty.call(schema, "additionalProperties")) {
    return "";
  }

  const additionalProperties = schema.additionalProperties;

  if (additionalProperties === false) {
    return '<div class="schema-children"><h5>Additional Properties</h5><p class="muted">No additional properties allowed.</p></div>';
  }

  if (additionalProperties === true) {
    return '<div class="schema-children"><h5>Additional Properties</h5><p class="muted">Any additional property value is allowed.</p></div>';
  }

  return [
    '<div class="schema-children">',
    '<h5>Additional Properties</h5>',
    renderSchema(additionalProperties, {
      id: state.id + "-additional-properties",
      path: state.path + ".*",
      depth: state.depth + 1,
      name: "additionalProperties",
    }),
    '</div>',
  ].join("");
}

function renderSchemaSummary(schema) {
  if (!schema) {
    return "";
  }

  return [
    '<p>',
    '<span class="schema-badge">' + escapeHtml(schemaType(schema)) + '</span>',
    schema.$ref ? " " + renderRefLink(schema.$ref) : "",
    '</p>',
  ].join("");
}

function renderExamples(source) {
  const blocks = [];

  if (source && Object.prototype.hasOwnProperty.call(source, "example")) {
    blocks.push(renderExampleBlock("Example", source.example));
  }

  if (source && isPlainObject(source.examples)) {
    for (const name of Object.keys(source.examples)) {
      const example = source.examples[name];
      const value = isPlainObject(example) && Object.prototype.hasOwnProperty.call(example, "value")
        ? example.value
        : example;
      const title = isPlainObject(example) && example.summary ? example.summary : name;
      blocks.push(renderExampleBlock(title, value));
    }
  }

  return blocks.length ? '<div class="examples-list">' + blocks.join("") + '</div>' : "";
}

function renderExampleBlock(title, value) {
  return [
    '<section class="example-block">',
    '<header><h4>' + escapeHtml(title) + '</h4></header>',
    '<pre class="json-block"><code>' + escapeHtml(formatJson(value)) + '</code></pre>',
    '</section>',
  ].join("");
}

function renderMarkdown(value) {
  const source = String(value || "").trim();

  if (!source) {
    return "";
  }

  const lines = source.replace(/\\r\\n?/g, "\\n").split("\\n");
  const blocks = [];
  let paragraph = [];
  let listItems = [];
  let codeLines = [];
  let inFence = false;

  function flushParagraph() {
    if (paragraph.length) {
      blocks.push('<p>' + renderInlineMarkdown(paragraph.join(" ")) + '</p>');
      paragraph = [];
    }
  }

  function flushList() {
    if (listItems.length) {
      blocks.push('<ul>' + listItems.map(function (item) {
        return '<li>' + renderInlineMarkdown(item) + '</li>';
      }).join("") + '</ul>');
      listItems = [];
    }
  }

  for (const line of lines) {
    if (line.trim().startsWith("\`\`\`")) {
      if (inFence) {
        blocks.push('<pre><code>' + escapeHtml(codeLines.join("\\n")) + '</code></pre>');
        codeLines = [];
        inFence = false;
      } else {
        flushParagraph();
        flushList();
        inFence = true;
      }

      continue;
    }

    if (inFence) {
      codeLines.push(line);
      continue;
    }

    if (!line.trim()) {
      flushParagraph();
      flushList();
      continue;
    }

    const heading = line.match(/^(#{1,6})\\s+(.+)$/);
    if (heading) {
      flushParagraph();
      flushList();
      const level = Math.min(6, heading[1].length + 2);
      blocks.push("<h" + level + ">" + renderInlineMarkdown(heading[2]) + "</h" + level + ">");
      continue;
    }

    const listItem = line.match(/^\\s*[-*]\\s+(.+)$/);
    if (listItem) {
      flushParagraph();
      listItems.push(listItem[1]);
      continue;
    }

    flushList();
    paragraph.push(line.trim());
  }

  if (inFence) {
    blocks.push('<pre><code>' + escapeHtml(codeLines.join("\\n")) + '</code></pre>');
  }

  flushParagraph();
  flushList();

  return blocks.length ? '<div class="markdown">' + blocks.join("") + '</div>' : "";
}

function renderInlineMarkdown(value) {
  const source = String(value || "");
  const tokenPattern = /(\`[^\`]+\`|\\[[^\\]]+\\]\\((?:https?:\\/\\/|#\\/)[^)\\s]+\\))/g;
  let result = "";
  let cursor = 0;
  let match;

  while ((match = tokenPattern.exec(source)) !== null) {
    result += escapeHtml(source.slice(cursor, match.index));
    result += renderInlineToken(match[0]);
    cursor = match.index + match[0].length;
  }

  result += escapeHtml(source.slice(cursor));
  return result;
}

function renderInlineToken(token) {
  if (token.startsWith("\`") && token.endsWith("\`")) {
    return '<code>' + escapeHtml(token.slice(1, -1)) + '</code>';
  }

  const link = token.match(/^\\[([^\\]]+)\\]\\(([^)]+)\\)$/);
  if (link) {
    return '<a href="' + safeUrl(link[2]) + '">' + escapeHtml(link[1]) + '</a>';
  }

  return escapeHtml(token);
}

function renderMethodBadge(method) {
  return '<span class="method-badge method-' + escapeHtml(String(method).toLowerCase()) + '">' + escapeHtml(String(method).toUpperCase()) + '</span>';
}

function renderTopicLink(topic) {
  return '<a href="#/topics/' + encodeRouteSegment(topic.slug) + '">' + escapeHtml(topic.title) + '</a>';
}

function renderTagLink(tag) {
  return '<a href="#/tags/' + encodeRouteSegment(tag.slug) + '">' + escapeHtml(tag.name) + '</a>';
}

function renderOperationLink(operation) {
  return [
    '<span class="operation-card">',
    '<a class="operation-link" href="#/operations/' + encodeRouteSegment(operation.id) + '">',
    renderMethodBadge(operation.method),
    '<span class="path-text">' + escapeHtml(operation.path) + '</span>',
    '</a>',
    '<span class="muted">' + escapeHtml(operation.summary || operation.operationId || operation.id) + '</span>',
    '</span>',
  ].join("");
}

function renderSchemaLink(schema) {
  return '<a href="#/schemas/' + encodeRouteSegment(schema.name) + '">' + escapeHtml(schema.name) + '</a>';
}

function renderRefLink(ref) {
  const schemaName = schemaNameFromRef(ref);

  if (schemaName) {
    return '<a href="#/schemas/' + encodeRouteSegment(schemaName) + '">' + escapeHtml(ref) + '</a>';
  }

  return '<code>' + escapeHtml(ref) + '</code>';
}

function schemaNameFromRef(ref) {
  const prefix = "#/components/schemas/";

  if (typeof ref === "string" && ref.startsWith(prefix)) {
    return decodeJsonPointerSegment(ref.slice(prefix.length));
  }

  return "";
}

function metadataItem(label, value) {
  return value ? '<li><strong>' + escapeHtml(label) + ':</strong> <span>' + escapeHtml(value) + '</span></li>' : "";
}

function formatJson(value) {
  if (typeof value === "string") {
    return value;
  }

  return JSON.stringify(value, null, 2);
}

function safeUrl(value) {
  const url = String(value || "");
  const isSafe =
    /^https?:\\/\\//.test(url) ||
    url.startsWith("#/") ||
    url.startsWith("./") ||
    url.startsWith("../") ||
    /^\\/(?!\\/)/.test(url) ||
    /^[A-Za-z0-9._-]+(?:\\/[A-Za-z0-9._-]+)*$/.test(url);

  return isSafe ? escapeHtml(url) : "#/";
}

function encodeRouteSegment(value) {
  return encodeURIComponent(String(value));
}

function decodeRouteSegment(value) {
  try {
    return decodeURIComponent(value);
  } catch (error) {
    return value;
  }
}

function decodeJsonPointerSegment(segment) {
  return decodeURIComponent(segment).replace(/~1/g, "/").replace(/~0/g, "~");
}

function slugify(value) {
  const words = String(value || "")
    .replace(/([a-z0-9])([A-Z])/g, "$1 $2")
    .normalize("NFKD")
    .replace(/[\\u0300-\\u036f]/g, "")
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");

  return words || "section";
}

function escapeHtml(value) {
  return String(value == null ? "" : value).replace(/[&<>"']/g, function (character) {
    return {
      "&": "&amp;",
      "<": "&lt;",
      ">": "&gt;",
      '"': "&quot;",
      "'": "&#39;",
    }[character];
  });
}

function isPlainObject(value) {
  return Boolean(value) && typeof value === "object" && !Array.isArray(value);
}

function arrayValue(value) {
  return Array.isArray(value) ? value : [];
}

window.addEventListener("hashchange", renderCurrentRoute);
renderCurrentRoute();
`;
}

function renderDocsDataJson(docsData) {
  return `${JSON.stringify(docsData, null, 2)}\n`;
}

function renderFiles(spec) {
  const docsData = normalizeApiDocs(spec.document);

  return new Map([
    ["index.html", renderIndexHtml(docsData)],
    ["styles.css", renderStylesCss()],
    ["app.js", renderAppJs(docsData)],
    ["openapi.yaml", spec.source],
    ["openapi.json", `${JSON.stringify(spec.document, null, 2)}\n`],
    ["api-docs.json", renderDocsDataJson(docsData)],
    [".nojekyll", ""],
  ]);
}

function writeFiles(outDir, files) {
  for (const [fileName, content] of files) {
    fs.writeFileSync(path.join(outDir, fileName), content, "utf8");
  }
}

function normalizeApiDocs(document) {
  const operations = normalizeOperations(document);
  const tags = normalizeTags(document, operations);

  return {
    api: normalizeApiInfo(document),
    topics: normalizeTopics(document),
    tags,
    operations,
    components: normalizeComponents(document),
    source: {
      openApiYaml: "openapi.yaml",
      openApiJson: "openapi.json",
    },
  };
}

function normalizeApiInfo(document) {
  const info = document.info || {};

  return {
    openapi: document.openapi,
    title: stringValue(info.title),
    description: stringValue(info.description),
    version: stringValue(info.version),
    servers: arrayValue(document.servers),
    externalDocs: objectValue(document.externalDocs),
  };
}

function normalizeTopics(document) {
  const slugs = new Set();

  return arrayValue(document["x-topics"]).map((topic, index) => {
    const title = stringValue(topic && topic.title) || `Topic ${index + 1}`;
    const slug = uniqueSlug(slugs, title);

    return {
      title,
      content: stringValue(topic && topic.content),
      slug,
      routeId: `topic-${slug}`,
    };
  });
}

function normalizeTags(document, operations) {
  const slugs = new Set();
  const operationIdsByTag = new Map();

  for (const operation of operations) {
    const tagName = operation.primaryTag;
    const operationIds = operationIdsByTag.get(tagName) || [];
    operationIds.push(operation.id);
    operationIdsByTag.set(tagName, operationIds);
  }

  const declaredTags = arrayValue(document.tags).map((tag) => {
    const name = stringValue(tag && tag.name) || "Untagged";
    const slug = uniqueSlug(slugs, name);

    return {
      name,
      description: stringValue(tag && tag.description),
      slug,
      routeId: `tag-${slug}`,
      operationIds: operationIdsByTag.get(name) || [],
    };
  });

  const declaredNames = new Set(declaredTags.map((tag) => tag.name));
  const inferredTags = Array.from(operationIdsByTag.keys())
    .filter((name) => !declaredNames.has(name))
    .map((name) => {
      const slug = uniqueSlug(slugs, name);

      return {
        name,
        description: "",
        slug,
        routeId: `tag-${slug}`,
        operationIds: operationIdsByTag.get(name) || [],
      };
    });

  return declaredTags.concat(inferredTags);
}

function normalizeOperations(document) {
  const operations = [];
  const ids = new Set();

  for (const [pathName, pathItem] of Object.entries(document.paths)) {
    if (!isPlainObject(pathItem)) {
      continue;
    }

    const pathParameters = arrayValue(pathItem.parameters);

    for (const [maybeMethod, operation] of Object.entries(pathItem)) {
      const method = maybeMethod.toLowerCase();

      if (!HTTP_METHODS.includes(method) || !isPlainObject(operation)) {
        continue;
      }

      const operationId = stringValue(operation.operationId) || operationRouteId(method, pathName);
      const id = uniqueId(ids, operationId);
      const tags = arrayValue(operation.tags).map(stringValue).filter(Boolean);
      const primaryTag = tags[0] || "Untagged";

      operations.push({
        id,
        operationId,
        routeId: `operation-${operationRouteId(method, pathName)}`,
        method,
        path: pathName,
        summary: stringValue(operation.summary),
        description: stringValue(operation.description),
        tags,
        primaryTag,
        parameters: pathParameters
          .concat(arrayValue(operation.parameters))
          .map((parameter) => normalizeParameter(document, parameter)),
        security: arrayValue(operation.security),
        requestBody: normalizeRequestBody(document, operation.requestBody),
        responses: normalizeResponses(document, operation.responses),
      });
    }
  }

  return operations;
}

function normalizeComponents(document) {
  const components = objectValue(document.components);

  return {
    schemas: normalizeComponentMap(
      components.schemas,
      (name, schema) => normalizeComponentSchema(document, name, schema),
    ),
    requestBodies: normalizeComponentMap(
      components.requestBodies,
      (name, requestBody) => ({
        name,
        routeId: `request-body-${slugify(name)}`,
        ...normalizeRequestBody(document, requestBody),
      }),
    ),
    responses: normalizeComponentMap(
      components.responses,
      (name, response) => ({
        name,
        routeId: `response-${slugify(name)}`,
        ...normalizeResponse(document, name, response),
      }),
    ),
  };
}

function normalizeComponentMap(componentMap, normalize) {
  if (!isPlainObject(componentMap)) {
    return [];
  }

  return Object.entries(componentMap).map(([name, value]) => normalize(name, value));
}

function normalizeComponentSchema(document, name, schema) {
  const ref = `#/components/schemas/${encodeJsonPointerSegment(name)}`;
  const shape = resolveDisplayValue(document, schema, new Set([ref]));

  return {
    name,
    description: stringValue(shape && shape.description),
    routeId: `schema-${slugify(name)}`,
    ref,
    shape,
  };
}

function normalizeParameter(document, parameter) {
  const ref = isPlainObject(parameter) ? parameter.$ref : undefined;
  const resolved = resolveDisplayValue(document, parameter);

  return {
    ref: stringValue(ref),
    name: stringValue(resolved && resolved.name),
    in: stringValue(resolved && resolved.in),
    description: stringValue(resolved && resolved.description),
    required: Boolean(resolved && resolved.required),
    deprecated: Boolean(resolved && resolved.deprecated),
    schema: normalizeSchemaForDisplay(document, resolved && resolved.schema),
    examples: objectValue(resolved && resolved.examples),
    example: resolved && Object.prototype.hasOwnProperty.call(resolved, "example")
      ? resolved.example
      : undefined,
  };
}

function normalizeRequestBody(document, requestBody) {
  if (!requestBody) {
    return null;
  }

  const ref = isPlainObject(requestBody) ? requestBody.$ref : undefined;
  const resolved = resolveDisplayValue(document, requestBody);

  return {
    ref: stringValue(ref),
    description: stringValue(resolved && resolved.description),
    required: Boolean(resolved && resolved.required),
    content: normalizeContent(document, resolved && resolved.content),
    shape: resolved,
  };
}

function normalizeResponses(document, responses) {
  if (!isPlainObject(responses)) {
    return [];
  }

  return Object.entries(responses).map(([status, response]) =>
    normalizeResponse(document, status, response),
  );
}

function normalizeResponse(document, status, response) {
  const ref = isPlainObject(response) ? response.$ref : undefined;
  const resolved = resolveDisplayValue(document, response);

  return {
    status: String(status),
    ref: stringValue(ref),
    description: stringValue(resolved && resolved.description),
    headers: objectValue(resolved && resolved.headers),
    content: normalizeContent(document, resolved && resolved.content),
    shape: resolved,
  };
}

function normalizeContent(document, content) {
  if (!isPlainObject(content)) {
    return [];
  }

  return Object.entries(content).map(([mediaType, media]) => ({
    mediaType,
    schema: normalizeSchemaForDisplay(document, media && media.schema),
    examples: objectValue(media && media.examples),
    example: media && Object.prototype.hasOwnProperty.call(media, "example")
      ? media.example
      : undefined,
    encoding: objectValue(media && media.encoding),
  }));
}

function normalizeSchemaForDisplay(document, schema) {
  return schema ? resolveDisplayValue(document, schema) : null;
}

function resolveDisplayValue(document, value, seenRefs = new Set()) {
  if (Array.isArray(value)) {
    return value.map((item) => resolveDisplayValue(document, item, seenRefs));
  }

  if (!isPlainObject(value)) {
    return value;
  }

  if (typeof value.$ref === "string") {
    if (seenRefs.has(value.$ref)) {
      return {
        $ref: value.$ref,
        circular: true,
      };
    }

    const nextSeenRefs = new Set(seenRefs);
    nextSeenRefs.add(value.$ref);
    const resolved = resolveDisplayValue(
      document,
      resolveLocalRef(document, value.$ref),
      nextSeenRefs,
    );

    if (isPlainObject(resolved)) {
      return {
        $ref: value.$ref,
        ...resolved,
      };
    }

    return resolved;
  }

  return Object.fromEntries(
    Object.entries(value).map(([key, nested]) => [
      key,
      resolveDisplayValue(document, nested, seenRefs),
    ]),
  );
}

function resolveLocalRef(document, ref) {
  if (typeof ref !== "string" || !ref.startsWith("#/")) {
    throw new GenerationError(`Only local OpenAPI references are supported for docs display: ${ref}`);
  }

  const segments = ref
    .slice(2)
    .split("/")
    .map(decodeJsonPointerSegment);

  let value = document;

  for (const segment of segments) {
    if (
      value == null ||
      !Object.prototype.hasOwnProperty.call(Object(value), segment)
    ) {
      throw new GenerationError(`Local OpenAPI reference not found: ${ref}`);
    }

    value = value[segment];
  }

  return value;
}

function slugify(value) {
  const words = String(value || "")
    .replace(/([a-z0-9])([A-Z])/g, "$1 $2")
    .normalize("NFKD")
    .replace(/[\u0300-\u036f]/g, "")
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");

  return words || "section";
}

function uniqueSlug(slugs, value) {
  return uniqueId(slugs, slugify(value));
}

function uniqueId(ids, value) {
  const base = slugify(value);
  let candidate = base;
  let suffix = 2;

  while (ids.has(candidate)) {
    candidate = `${base}-${suffix}`;
    suffix += 1;
  }

  ids.add(candidate);
  return candidate;
}

function operationRouteId(method, pathName) {
  return slugify(`${method} ${pathName.replace(/[{}]/g, " ")}`);
}

function decodeJsonPointerSegment(segment) {
  return decodeURIComponent(segment).replace(/~1/g, "/").replace(/~0/g, "~");
}

function encodeJsonPointerSegment(segment) {
  return String(segment).replace(/~/g, "~0").replace(/\//g, "~1");
}

function serializeJsonForScript(value) {
  return JSON.stringify(value, null, 2)
    .replace(/</g, "\\u003c")
    .replace(/\u2028/g, "\\u2028")
    .replace(/\u2029/g, "\\u2029");
}

function isPlainObject(value) {
  return Boolean(value) && typeof value === "object" && !Array.isArray(value);
}

function stringValue(value) {
  return typeof value === "string" ? value : "";
}

function arrayValue(value) {
  return Array.isArray(value) ? value : [];
}

function objectValue(value) {
  return isPlainObject(value) ? value : {};
}

function escapeHtml(value) {
  return value
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;");
}

function generate(cwd, argv) {
  const options = parseArgs(argv);

  if (options.selfTest) {
    runSelfTests();
    return {
      outDir: cwd,
      files: [],
      selfTest: true,
    };
  }

  const paths = resolvePaths(cwd, options);

  assertSpecExists(paths.specPath);

  const spec = loadSpec(paths.specPath);
  assertOpenApiDocument(spec.document);

  const files = renderFiles(spec);

  prepareOutput(paths.outDir);
  writeFiles(paths.outDir, files);

  return {
    outDir: paths.outDir,
    files: Array.from(files.keys()),
  };
}

function main() {
  try {
    const result = generate(process.cwd(), process.argv.slice(2));

    if (result.selfTest) {
      console.log("Generator self-tests passed");
    } else {
      console.log(
        `Generated API docs in ${path.relative(process.cwd(), result.outDir) || "."}`,
      );
    }
  } catch (error) {
    const prefix = error instanceof UsageError ? "Usage error" : "Generation error";
    console.error(`${prefix}: ${error.message}`);
    process.exitCode = 1;
  }
}

function runSelfTests() {
  const assert = require("node:assert/strict");
  const vm = require("node:vm");
  const slugs = new Set();
  const localDocument = {
    openapi: "3.0.2",
    info: {
      title: "Test API",
      version: "1.0.0",
    },
    paths: {
      "/machines/{machineSlug}": {
        get: {
          tags: ["Machine versions"],
          parameters: [
            {
              name: "machineSlug",
              in: "path",
              schema: {
                $ref: "#/components/schemas/MachineSlug",
              },
            },
          ],
          requestBody: {
            $ref: "#/components/requestBodies/CreateMachine",
          },
          responses: {
            "403": {
              $ref: "#/components/responses/Forbidden",
            },
          },
        },
      },
    },
    components: {
      requestBodies: {
        CreateMachine: {
          description: "Create a machine",
          content: {
            "application/json": {
              schema: {
                $ref: "#/components/schemas/MachineSlug",
              },
            },
          },
        },
      },
      responses: {
        Forbidden: {
          description: "Forbidden",
          content: {
            "application/json": {
              schema: {
                $ref: "#/components/schemas/Error",
              },
            },
          },
        },
      },
      schemas: {
        MachineSlug: {
          type: "string",
          description: "Machine slug",
        },
        Error: {
          type: "object",
          properties: {
            message: {
              type: "string",
            },
          },
        },
        StateValue: {
          oneOf: [
            {
              $ref: "#/components/schemas/SimpleStateValue",
            },
            {
              $ref: "#/components/schemas/CompoundStateValue",
            },
          ],
        },
        SimpleStateValue: {
          type: "string",
        },
        CompoundStateValue: {
          type: "object",
          additionalProperties: {
            $ref: "#/components/schemas/StateValue",
          },
        },
      },
    },
  };

  assert.equal(slugify("Machine versions"), "machine-versions");
  assert.equal(operationRouteId("get", "/machines/{machineSlug}"), "get-machines-machine-slug");
  assert.equal(resolveLocalRef(localDocument, "#/components/schemas/MachineSlug").type, "string");
  assert.equal(uniqueSlug(slugs, "Duplicate!! Tag"), "duplicate-tag");
  assert.equal(uniqueSlug(slugs, "Duplicate Tag"), "duplicate-tag-2");

  const operations = normalizeOperations(localDocument);
  assert.equal(operations.length, 1);
  assert.equal(operations[0].id, "get-machines-machine-slug");
  assert.equal(operations[0].parameters[0].schema.description, "Machine slug");
  assert.equal(operations[0].requestBody.description, "Create a machine");
  assert.equal(operations[0].responses[0].description, "Forbidden");
  assert.equal(
    localDocument.paths["/machines/{machineSlug}"].get.requestBody.$ref,
    "#/components/requestBodies/CreateMachine",
  );

  assert.throws(
    () => assertOpenApiDocument({ openapi: "3.0.2", info: {} }),
    /paths object/,
  );

  const docsData = normalizeApiDocs(localDocument);
  assert.equal(
    docsData.components.schemas.find((schema) => schema.name === "CompoundStateValue")
      .shape.additionalProperties.$ref,
    "#/components/schemas/StateValue",
  );
  const indexHtml = renderIndexHtml(docsData);
  const appJs = renderAppJs(docsData);
  const docsJson = renderDocsDataJson(docsData);

  assert.match(indexHtml, /<header class="docs-header">/);
  assert.match(indexHtml, /<aside class="docs-sidebar" aria-label="Documentation navigation">/);
  assert.match(indexHtml, /<main id="docs-content"/);
  assert.match(indexHtml, /<input id="docs-search"/);
  assert.match(indexHtml, /href="openapi\.yaml"/);
  assert.match(indexHtml, /href="openapi\.json"/);
  assert.match(indexHtml, /data-route-pattern="#\/operations\/:slug"/);
  assert.doesNotMatch(indexHtml, /https?:\/\//);
  assert.match(appJs, /const apiDocsData = /);
  assert.match(appJs, /"#\/schemas\/:slug"/);
  assert.match(appJs, /function parseRoute/);
  assert.match(appJs, /function renderMarkdown/);
  assert.match(appJs, /function renderSchema/);
  assert.doesNotMatch(appJs, /\bfetch\s*\(/);
  assert.equal(JSON.parse(docsJson).api.title, "Test API");
  assert.equal(escapeHtml("<script>"), "&lt;script&gt;");
  assert.match(serializeJsonForScript({ tag: "</script>" }), /\\u003c\/script>/);

  const renderedOverview = renderGeneratedRoute(vm, appJs, "#/");
  assert.match(renderedOverview, /Test API/);
  assert.match(renderedOverview, /OpenAPI YAML/);

  const renderedOperation = renderGeneratedRoute(
    vm,
    appJs,
    "#/operations/get-machines-machine-slug",
  );
  assert.match(renderedOperation, /Machine slug/);
  assert.match(renderedOperation, /#\/schemas\/MachineSlug/);
  assert.match(renderedOperation, /Request Body/);
  assert.match(renderedOperation, /Responses/);

  const renderedSchema = renderGeneratedRoute(vm, appJs, "#/schemas/Error");
  assert.match(renderedSchema, /Properties/);
  assert.match(renderedSchema, /message/);

  const renderedMapSchema = renderGeneratedRoute(vm, appJs, "#/schemas/CompoundStateValue");
  assert.match(renderedMapSchema, /Additional Properties/);
  assert.match(renderedMapSchema, /#\/schemas\/StateValue/);

  const renderedNotFound = renderGeneratedRoute(vm, appJs, "#/missing");
  assert.match(renderedNotFound, /Route not found/);
  assert.match(renderedNotFound, /Back to overview/);
}

function renderGeneratedRoute(vm, appJs, hash) {
  const content = {
    innerHTML: "",
    focus() {},
  };
  const context = {
    console: {
      error(...args) {
        throw new Error(args.join(" "));
      },
      log() {},
      warn() {},
    },
    document: {
      documentElement: {
        dataset: {},
      },
      getElementById(id) {
        return id === "docs-content" ? content : null;
      },
      querySelectorAll() {
        return [];
      },
    },
    window: {
      location: {
        hash,
      },
      addEventListener() {},
    },
    Set,
    Object,
    String,
    Array,
    Boolean,
    JSON,
    RegExp,
    encodeURIComponent,
    decodeURIComponent,
  };

  context.globalThis = context;
  vm.runInNewContext(appJs, context, { filename: "generated-app.js" });
  return content.innerHTML;
}

if (require.main === module) {
  main();
}
